任务、任务详情查看。","code":"1.3.1.5","level":4,"status":"STATUS_ACTIVE","depends":"","start":1776960000000,"duration":1,"end":1777046399999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":1,"latestStart":57,"latestFinish":58,"criticalCost":1,"isCritical":false,"inPeople":"中汽研"},{"id":"tmp_1774400751017","name":"交通事件管理","progress":"50.00","progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"","code":"1.3.2","level":3,"status":"STATUS_ACTIVE","depends":"","start":1776960000000,"duration":2,"end":1777132799999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":2,"latestStart":56,"latestFinish":58,"criticalCost":2,"isCritical":false},{"id":"tmp_1774400947626","name":"事件动态管理","progress":50,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"系统自动生成交通事件发布情况提供动态滚动播报记录，为用户实现车路协同交通事件运营服务。支持事件列表查看、事件位置查看、事件详情查看。","code":"1.3.2.1","level":4,"status":"STATUS_ACTIVE","depends":"","start":1776960000000,"duration":1,"end":1777046399999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":1,"latestStart":57,"latestFinish":58,"criticalCost":1,"isCritical":false,"inPeople":"中汽研"},{"id":"tmp_1774400954514","name":"事件发布记录","progress":50,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"支持对人工、设备上报、第三方上报交通事件情况列表化浏览，以及取消事件、删除记录、清除事件内容操作。","code":"1.3.2.2","level":4,"status":"STATUS_ACTIVE","depends":"","start":1777046400000,"duration":1,"end":1777132799999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":1,"latestStart":57,"latestFinish":58,"criticalCost":1,"isCritical":false,"inPeople":"中汽研"},{"id":"tmp_1774400956563","name":"自动转发规则","progress":50,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"配置平台收到由设备或者第三方接入数据创建的事件转发规则。按照事件类型区分不同响应策略。支持转发规则列表查看、转发规则列表查询、转发规则编辑、转发规则取消。","code":"1.3.2.3","level":4,"status":"STATUS_ACTIVE","depends":"","start":1777046400000,"duration":1,"end":1777132799999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":1,"latestStart":57,"latestFinish":58,"criticalCost":1,"isCritical":false,"inPeople":"中汽研"},{"id":"tmp_1774400760066","name":"标志标牌管理","progress":"50.00","progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"","code":"1.3.3","level":3,"status":"STATUS_ACTIVE","depends":"","start":1774540800000,"duration":31,"end":1777219199999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":31,"latestStart":27,"latestFinish":58,"criticalCost":31,"isCritical":false},{"id":"tmp_1774400911006","name":"标志标牌资源概览","progress":50,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"管理和维护标志标牌资源信息，同时支持标志标牌列表模式和地图模式分布查看。支持标志标牌列表查看、标志标牌列表查询、标志标牌添加、标志标牌编辑、标志标牌删除、标志标牌详情查看、标志标牌失效设置。","code":"1.3.3.1","level":4,"status":"STATUS_ACTIVE","depends":"","start":1777132800000,"duration":1,"end":1777219199999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":1,"latestStart":57,"latestFinish":58,"criticalCost":1,"isCritical":false,"inPeople":"中汽研"},{"id":"tmp_1774400917500","name":"导入标志标牌资源","progress":50,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"用户可以通过导入标志标牌资源文件（json 格式），在本平台填写在线完善对应的属性信息，并在平台端按照单个标志标牌信息进行存储及管理。支持导入标志标牌文件、编辑标志标牌信息。","code":"1.3.3.2","level":4,"status":"STATUS_ACTIVE","depends":"","start":1774540800000,"duration":1,"end":1774627199999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":1,"latestStart":57,"latestFinish":58,"criticalCost":1,"isCritical":false,"inPeople":"中汽研"},{"id":"tmp_1774400919466","name":"标志标牌任务下发","progress":50,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"用户可以将平台已管理的标志标牌信息，按照设备发布需要进行全局更新，提供至设备处进行使用。支持任务列表查看、任务列表查询、添加发布任务、停止任务、重发任务、任务详情查看。","code":"1.3.3.3","level":4,"status":"STATUS_ACTIVE","depends":"","start":1774627200000,"duration":1,"end":1774713599999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":1,"latestStart":57,"latestFinish":58,"criticalCost":1,"isCritical":false,"inPeople":"中汽研"},{"id":"tmp_fk1774343471931_1","name":"应用管理系统 （web端）","progress":"50.00","progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"","code":"1.4","level":2,"status":"STATUS_ACTIVE","depends":"","start":1777305600000,"duration":11,"end":1778255999999,"startIsMilestone":false,"endIsMilestone":true,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":11,"latestStart":47,"latestFinish":58,"criticalCost":11,"isCritical":false},{"id":"tmp_fk1774401094898_1","name":"统一账户管理","progress":"50.00","progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"","code":"1.4.1","level":3,"status":"STATUS_ACTIVE","depends":"","start":1777305600000,"duration":3,"end":1777564799999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":3,"latestStart":55,"latestFinish":58,"criticalCost":3,"isCritical":false},{"id":"tmp_1774401151963","name":"组织管理","progress":50,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"管理和维护系统组织信息，隔离不同组织数据权限。支持组织列表查看、组织列表查询、添加组织、编辑组织、删除组织、组织权限设置、组织配置、组织启用、组织停用。","code":"1.4.1.1","level":4,"status":"STATUS_ACTIVE","depends":"","start":1777305600000,"duration":1,"end":1777391999999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":1,"latestStart":57,"latestFinish":58,"criticalCost":1,"isCritical":false,"inPeople":"中汽研"},{"id":"tmp_1774401159045","name":"用户管理","progress":50,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"管理和维护系统用户及管理员登录账号信息。支持用户列表查看、用户列表查询、添加用户、编辑用户、删除用户、冻结账号、解冻账号、重置密码。","code":"1.4.1.2","level":4,"status":"STATUS_ACTIVE","depends":"","start":1777392000000,"duration":1,"end":1777478399999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":1,"latestStart":57,"latestFinish":58,"criticalCost":1,"isCritical":false,"inPeople":"中汽研"},{"id":"tmp_1774401162778","name":"角色管理","progress":50,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"管理和维护系统角色及角色权限分配。支持角色列表查看、角色列表查询、添加角色、编辑角色、删除角色、角色权限设置。","code":"1.4.1.3","level":4,"status":"STATUS_ACTIVE","depends":"","start":1777478400000,"duration":1,"end":1777564799999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":1,"latestStart":57,"latestFinish":58,"criticalCost":1,"isCritical":false,"inPeople":"中汽研"},{"id":"tmp_1774401108181","name":"设备接入管理","progress":"50.00","progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"","code":"1.4.2","level":3,"status":"STATUS_ACTIVE","depends":"","start":1777564800000,"duration":8,"end":1778255999999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":8,"latestStart":50,"latestFinish":58,"criticalCost":8,"isCritical":false},{"id":"tmp_1774402058348","name":"设备类型管理","progress":50,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"对场端 V2X 设备不同设备类型进行管理，为接入设备统一了类型，定义了具体设备分类。可方便快捷创建类型，可直观查看总体接入设备类型数以及子产品、子设备数量。支持设备类型列表查看、设备类型列表查询、添加设备类型、编辑设备类型、删除设备类型、设备类型下产品数量统计、设备类型下设备数量统计。","code":"1.4.2.1","level":4,"status":"STATUS_ACTIVE","depends":"","start":1777564800000,"duration":2,"end":1777737599999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":2,"latestStart":56,"latestFinish":58,"criticalCost":2,"isCritical":false,"inPeople":"中汽研"},{"id":"tmp_1774402066715","name":"产品管理","progress":50,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"对场端 V2X 设备进行产品分类管理，以及对产品物模型进行编辑，管理设备具备的能力和属性，为设备快速接入提供产品相关信息。支持产品列表查看、产品列表查询、添加产品类型、编辑产品类型、删除产品类型、启用产品类型、停用产品类型、产品类型详情查看。","code":"1.4.2.2","level":4,"status":"STATUS_ACTIVE","depends":"","start":1777737600000,"duration":3,"end":1777996799999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":3,"latestStart":55,"latestFinish":58,"criticalCost":3,"isCritical":false,"inPeople":"中汽研"},{"id":"tmp_1774402068307","name":"设备管理","progress":50,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"对场端 V2X 设备进行接入管理，提供设备接入时的认证和注册工作，在线监控运行状态，对设备全生命周期进行管理。支持设备列表查看、设备列表查询、添加设备、编辑设备、删除设备、启用设备、停用设备、设备详情查看。","code":"1.4.2.3","level":4,"status":"STATUS_ACTIVE","depends":"","start":1777910400000,"duration":3,"end":1778169599999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":3,"latestStart":55,"latestFinish":58,"criticalCost":3,"isCritical":false,"inPeople":"中汽研"},{"id":"tmp_1774402069625","name":"协议管理","progress":50,"progressByWorklog":false,"description":"设备接入平台以协议管理为基础支持多种协议接入，适应不同设备需求，确保不同设备都能接入平台。支持协议列表查看、协议列表查询、添加协议、编辑协议、删除协议、下载 jar 包。","code":"1.4.2.4","level":4,"status":"STATUS_ACTIVE","depends":"","start":1778169600000,"duration":1,"end":1778255999999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":1,"latestStart":57,"latestFinish":58,"criticalCost":1,"isCritical":false,"inPeople":"重理工"},{"id":"tmp_fk1774421079518_1","name":"路侧融合感知系统","progress":"0.00","progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"","code":2,"level":1,"status":"STATUS_ACTIVE","depends":"","start":1773849600000,"duration":48,"end":1777996799999,"startIsMilestone":false,"endIsMilestone":true,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":48,"latestStart":10,"latestFinish":58,"criticalCost":48,"isCritical":false},{"id":"tmp_fk1774421095233_1","name":"感知子系统","progress":0,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"该子系统包含工业摄像机、毫米波雷达、激光雷达等感知终端设备。","code":"2.1","level":2,"status":"STATUS_ACTIVE","depends":"","start":1773849600000,"duration":13,"end":1774972799999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":13,"latestStart":45,"latestFinish":58,"criticalCost":13,"isCritical":false,"inPeople":"重理工"},{"id":"tmp_fk1774421102645_1","name":"边缘计算子系统","progress":0,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"该子系统是指路侧边缘计算单元，它对感知子系统所采集的数据进行融合计算。路侧 边缘计算单元安装于路口机柜内，接入汇聚交换机。","code":"2.2","level":2,"status":"STATUS_ACTIVE","depends":"","start":1774886400000,"duration":18,"end":1776441599999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":18,"latestStart":40,"latestFinish":58,"criticalCost":18,"isCritical":false,"inPeople":"重理工"},{"id":"tmp_fk1774421116703_1","name":"传输子系统","progress":0,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"该子系统包含路侧通信单元RSU、交换机以及网络和光缆。路侧通信单元 RSU 一般安装在路侧杆件上，实际布置时应以不影响设备正常功能无遮挡为前提，根据路况、施工便利程度进行调整，主要提供 V2X短距离无线通信能力。交换机安装于机柜内，提供接入和汇聚能力。设备接入采用网线，交换机之间采用光 缆连接，线缆采用相应的管、盒提供保护能力。","code":"2.3","level":2,"status":"STATUS_ACTIVE","depends":"","start":1776355200000,"duration":19,"end":1777996799999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":19,"latestStart":39,"latestFinish":58,"criticalCost":19,"isCritical":false,"inPeople":"重理工"},{"id":"tmp_fk1774421241189_1","name":"高精地图","progress":"0.00","progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"","code":3,"level":1,"status":"STATUS_ACTIVE","depends":"","start":1774972800000,"duration":17,"end":1776441599999,"startIsMilestone":false,"endIsMilestone":true,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":17,"latestStart":41,"latestFinish":58,"criticalCost":17,"isCritical":false},{"id":"tmp_fk1774421249079_1","name":"采集范围","progress":0,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"高精度地图数据应包括道路属性数据、几何数据、关联关系数据。道路属性数据应包 括车道模型数据(类型、通行状态、数量和通行方向等)和车道线模型数据(类型、颜色、 宽度和编号等)。","code":"3.1","level":2,"status":"STATUS_ACTIVE","depends":"","start":1774972800000,"duration":2,"end":1775145599999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":2,"latestStart":56,"latestFinish":58,"criticalCost":2,"isCritical":false,"inPeople":"图商"},{"id":"tmp_fk1774421260862_1","name":"地图要素","progress":0,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"高精度地图数据采集制作范围应包含各类道路、道路附属设施数据、进出停车场外延 道路数据、停车要素数据。","code":"3.2","level":2,"status":"STATUS_ACTIVE","depends":"","start":1775145600000,"duration":3,"end":1775404799999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":3,"latestStart":55,"latestFinish":58,"criticalCost":3,"isCritical":false,"inPeople":"图商"},{"id":"tmp_fk1774421266093_1","name":"数据结构","progress":0,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"高精度地图数据应包括道路属性数据、几何数据、关联关系数据。道路属性数据应包 括车道模型数据(类型、通行状态、数量和通行方向等)和车道线模型数据(类型、颜色、 宽度和编号等)。","code":"3.3","level":2,"status":"STATUS_ACTIVE","depends":"","start":1775404800000,"duration":6,"end":1775923199999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":6,"latestStart":52,"latestFinish":58,"criticalCost":6,"isCritical":false,"inPeople":"图商"},{"id":"tmp_fk1774421279562_1","name":"数据格式","progress":0,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"高精度地图数据应包括但不限于：矢量数据、激光点云数据、视觉数据、全景照片、 三维模型数据、opendrive 或 NDS 数据，支持生成 shp 文件与匹配的geo.json  格式数据文件。","code":"3.4","level":2,"status":"STATUS_ACTIVE","depends":"","start":1775836800000,"duration":4,"end":1776182399999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":4,"latestStart":54,"latestFinish":58,"criticalCost":4,"isCritical":false,"inPeople":"图商"},{"id":"tmp_fk1774421284504_1","name":"数据精度","progress":0,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"高精度地图采用CGCS2000 坐标，数据精度需保证绝对精度≤0.8m,  相对精度≤0.2m。高精度地图中涉及的所有道路、车位、立柱、墙体等位置应是全量数据，不在制图范 围内的路段，应至少采集300m 或不足300m 的应采集至下一个区域。高精度地图应满足具备主流设备厂家或者集成厂家使用的要求。","code":"3.5","level":2,"status":"STATUS_ACTIVE","depends":"","start":1776182400000,"duration":3,"end":1776441599999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":3,"latestStart":55,"latestFinish":58,"criticalCost":3,"isCritical":false,"inPeople":"图商"},{"id":"tmp_fk1774421449317_1","name":"车辆对接","progress":"0.00","progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"","code":4,"level":1,"status":"STATUS_ACTIVE","depends":"","start":1775404800000,"duration":12,"end":1776441599999,"startIsMilestone":false,"endIsMilestone":true,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":12,"latestStart":46,"latestFinish":58,"criticalCost":12,"isCritical":false},{"id":"tmp_fk1774421462605_1","name":"标准接口","progress":0,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"AVP 系统所实现的功能旨在为车端提供AVP 代客泊车相关服务，主要为车端提供AVP 停车场的车位预约服务、高精度地图服务、自动泊车和接驾路径规划服务，该三类服务为 车端提供的标准对接接口。支持代客泊车的车辆需要车企或运营方提供，不在AVP 软件系 统建设范围内。","code":"4.1","level":2,"status":"STATUS_ACTIVE","depends":"","start":1775404800000,"duration":5,"end":1775836799999,"startIsMilestone":false,"endIsMilestone":false,"collapsed":false,"canWrite":true,"canAdd":true,"canDelete":true,"canAddIssue":true,"assigs":[],"earlyStart":0,"earlyFinish":5,"latestStart":53,"latestFinish":58,"criticalCost":5,"isCritical":false,"inPeople":"重理工"},{"id":"tmp_fk1774421470901_1","name":"对接萝卜快跑","progress":0,"progressByWorklog":false,"relevance":0,"type":"","typeId":"","description":"在萝卜快跑车辆运营方开放数据接口，支持本项目与其做数据对接的前提下，本项目 拟计划与萝卜快跑车辆对接，实现数据共享，支持萝卜快跑车辆进入研发基地地上地下指 定车位，实现自动泊车。","c